####################################################################
# DataVault — Environment Configuration
# Copy to .env and fill in real values. NEVER commit .env to git.
####################################################################

# ── App ────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=replace_with_random_32_char_string_here
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Frontend ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXTAUTH_SECRET=replace_with_random_secret
NEXTAUTH_URL=https://yourdomain.com

# ── Redis ──────────────────────────────────────────────────────
REDIS_PASSWORD=replace_with_strong_redis_password

# ── Qdrant Vector DB ───────────────────────────────────────────
QDRANT_API_KEY=replace_with_qdrant_api_key_or_leave_empty

# ── Ollama LLM ─────────────────────────────────────────────────
OLLAMA_MODEL=mistral          # or: llama3, phi3, gemma2, codellama
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED=1

# ── Celery Workers ─────────────────────────────────────────────
WORKER_REPLICAS=2

# ── Scraping ───────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=5
REQUEST_TIMEOUT=30

# ── Flower Monitoring ──────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASS=replace_with_flower_password
